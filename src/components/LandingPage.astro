---
import { alternateLinks, siteMeta, type Locale, type PageContent } from "../data/site";

interface Props {
  locale: Locale;
  content: PageContent;
}

const { locale, content } = Astro.props;
const phoneHref = `tel:${siteMeta.phone.replace(/\s+/g, "")}`;
const displayAddress = locale === "zh" ? siteMeta.addressZh : siteMeta.address;
const displayPlusCode = locale === "zh" ? siteMeta.plusCodeZh : siteMeta.plusCode;
const typeValueByLocale: Record<Locale, string> = {
  zh: "旅游胜地",
  en: "Tourist attraction",
  it: "Attrazione turistica",
  es: "Atracción turística",
};
---

<div class="min-h-screen">
  <header class="sticky top-0 z-30 border-b border-white/30 bg-[#f7f5ef]/85 backdrop-blur">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 lg:px-8">
      <a href={locale === "zh" ? "/" : `/${locale}/`} class="text-sm font-semibold tracking-[0.18em] text-slate-700 uppercase">
        {siteMeta.name}
      </a>
      <nav class="hidden gap-6 text-sm text-slate-600 md:flex">
        <a href="#overview" class="hover:text-slate-900">{content.nav.overview}</a>
        <a href="#gallery" class="hover:text-slate-900">{content.nav.gallery}</a>
        <a href="#reviews" class="hover:text-slate-900">{content.nav.reviews}</a>
        <a href="#visit" class="hover:text-slate-900">{content.nav.visit}</a>
        <a href="#links" class="hover:text-slate-900">{content.nav.links}</a>
      </nav>
      <div class="flex flex-wrap justify-end gap-2">
        {
          alternateLinks.map((item) => {
            const isActive = item.locale === locale;
            return (
              <a
                href={item.href}
                hreflang={item.locale === "zh" ? "zh-CN" : item.locale}
                class:list={[
                  "rounded-full border px-3 py-1.5 text-xs font-medium",
                  isActive
                    ? "border-slate-900 bg-slate-900 text-white"
                    : "border-slate-300 text-slate-700 hover:border-slate-500 hover:text-slate-950",
                ]}
              >
                {item.label}
              </a>
            );
          })
        }
      </div>
    </div>
  </header>

  <main>
    <section class="relative isolate overflow-hidden">
      <div
        class="absolute inset-0 bg-cover bg-center"
        style={`background-image:url(${siteMeta.heroImage});`}
      ></div>
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(7,15,24,0.22),rgba(7,15,24,0.72))]"></div>
      <div class="relative mx-auto grid min-h-[84vh] max-w-7xl gap-10 px-5 py-16 lg:grid-cols-[1.3fr_0.7fr] lg:px-8 lg:py-24">
        <div class="flex flex-col justify-end">
          <span class="mb-4 inline-flex w-fit rounded-full border border-white/20 bg-white/10 px-4 py-1 text-xs tracking-[0.18em] text-white/90 uppercase">
            {content.hero.eyebrow}
          </span>
          <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-white md:text-6xl">
            {content.hero.headline}
          </h1>
          <p class="mt-6 max-w-2xl text-base leading-7 text-white/85 md:text-lg">
            {content.hero.summary}
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href={siteMeta.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-950 hover:bg-slate-100"
            >
              {content.hero.mapsCta}
            </a>
            <a
              href="#gallery"
              class="rounded-full border border-white/35 px-5 py-3 text-sm font-semibold text-white hover:border-white hover:bg-white/10"
            >
              {content.hero.galleryCta}
            </a>
          </div>
        </div>

        <aside class="self-end rounded-[2rem] border border-white/15 bg-white/12 p-6 text-white shadow-2xl backdrop-blur-md">
          <h2 class="text-sm font-semibold tracking-[0.18em] text-white/75 uppercase">
            {content.metricsTitle}
          </h2>
          <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
            <div class="rounded-2xl border border-white/10 bg-black/10 p-4">
              <div class="text-xs uppercase tracking-[0.16em] text-white/60">{content.hero.ratingLabel}</div>
              <div class="mt-2 text-3xl font-semibold">
                {siteMeta.rating}
                <span class="ml-2 text-base font-normal text-white/70">({siteMeta.reviewCount})</span>
              </div>
            </div>
            <div class="rounded-2xl border border-white/10 bg-black/10 p-4">
              <div class="text-xs uppercase tracking-[0.16em] text-white/60">{content.hero.typeLabel}</div>
              <div class="mt-2 text-lg font-medium">{typeValueByLocale[locale]}</div>
            </div>
            <div class="rounded-2xl border border-white/10 bg-black/10 p-4">
              <div class="text-xs uppercase tracking-[0.16em] text-white/60">{content.hero.addressLabel}</div>
              <div class="mt-2 text-sm leading-6 text-white/85">{displayAddress}</div>
            </div>
            <div class="rounded-2xl border border-white/10 bg-black/10 p-4">
              <div class="text-xs uppercase tracking-[0.16em] text-white/60">{content.hero.phoneLabel}</div>
              <a href={phoneHref} class="mt-2 block text-sm leading-6 text-white/85 hover:text-white">
                {siteMeta.phone}
              </a>
            </div>
            <div class="rounded-2xl border border-white/10 bg-black/10 p-4 sm:col-span-2 lg:col-span-1">
              <div class="text-xs uppercase tracking-[0.16em] text-white/60">{content.hero.plusCodeLabel}</div>
              <div class="mt-2 text-sm leading-6 text-white/85">{displayPlusCode}</div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section id="overview" class="mx-auto max-w-7xl px-5 py-18 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr]">
        <div>
          <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">
            {content.metricsTitle}
          </p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950">
            {content.story.title}
          </h2>
          <p class="mt-5 max-w-xl text-base leading-7 text-slate-600">{content.story.intro}</p>
          <div class="mt-8 grid gap-3 sm:grid-cols-2">
            {
              content.metrics.map((item) => (
                <div class="rounded-2xl border border-stone-200/80 bg-white/75 p-4 shadow-sm shadow-stone-200/40">
                  <div class="text-xs uppercase tracking-[0.16em] text-slate-500">{item.label}</div>
                  <div class="mt-2 text-sm leading-6 text-slate-800">{item.value}</div>
                </div>
              ))
            }
          </div>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
          {
            content.story.cards.map((card) => (
              <article class="rounded-[1.75rem] border border-stone-200/80 bg-white/85 p-6 shadow-sm shadow-stone-200/40">
                <h3 class="text-lg font-semibold text-slate-900">{card.title}</h3>
                <p class="mt-4 text-sm leading-7 text-slate-600">{card.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="gallery" class="border-y border-stone-200/70 bg-white/55">
      <div class="mx-auto max-w-7xl px-5 py-18 lg:px-8">
        <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
          <div class="max-w-3xl">
            <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">
              {content.nav.gallery}
            </p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950">
              {content.photos.title}
            </h2>
            <p class="mt-5 text-base leading-7 text-slate-600">{content.photos.intro}</p>
          </div>
          <a
            href={siteMeta.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-fit rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:border-slate-900 hover:text-slate-950"
          >
            {content.photos.mapsCta}
          </a>
        </div>
        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {
            siteMeta.galleryImages.map((image) => (
              <figure class="group overflow-hidden rounded-[1.5rem] border border-stone-200/70 bg-stone-100 shadow-sm shadow-stone-200/50">
                <img
                  src={image.src}
                  alt={`${content.photos.altPrefix} ${image.index}`}
                  loading="lazy"
                  class="aspect-[4/3] w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                />
              </figure>
            ))
          }
        </div>
      </div>
    </section>

    <section id="reviews" class="mx-auto max-w-7xl px-5 py-18 lg:px-8">
      <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">
            {content.nav.reviews}
          </p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950">
            {content.reviews.title}
          </h2>
          <p class="mt-5 text-base leading-7 text-slate-600">{content.reviews.intro}</p>
        </div>
        <a
          href={siteMeta.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="w-fit rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:border-slate-900 hover:text-slate-950"
        >
          {content.reviews.mapsCta}
        </a>
      </div>
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {
          content.reviews.themes.map((theme) => (
            <article class="rounded-[1.75rem] border border-stone-200/80 bg-white/85 p-6 shadow-sm shadow-stone-200/40">
              <h3 class="text-lg font-semibold text-slate-900">{theme.title}</h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">{theme.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="visit" class="bg-slate-950 text-white">
      <div class="mx-auto max-w-7xl px-5 py-18 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.7fr_1.3fr]">
          <div>
            <p class="text-sm font-semibold tracking-[0.18em] text-white/55 uppercase">
              {content.nav.visit}
            </p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight">{content.visit.title}</h2>
            <div class="mt-8 rounded-[1.75rem] border border-white/10 bg-white/5 p-6">
              <h3 class="text-lg font-semibold">{content.editorial.title}</h3>
              <p class="mt-4 text-sm leading-7 text-white/70">{content.editorial.body}</p>
            </div>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            {
              content.visit.cards.map((card) => (
                <article class="rounded-[1.75rem] border border-white/10 bg-white/5 p-6">
                  <h3 class="text-lg font-semibold">{card.title}</h3>
                  <p class="mt-4 text-sm leading-7 text-white/70">{card.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section id="links" class="mx-auto max-w-7xl px-5 py-18 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">
          {content.nav.links}
        </p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950">{content.links.title}</h2>
        <p class="mt-5 text-base leading-7 text-slate-600">{content.links.intro}</p>
      </div>
      <div class="mt-10 grid gap-4 md:grid-cols-2">
        {
          content.links.items.map((item) => (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-[1.75rem] border border-stone-200/80 bg-white/85 p-6 shadow-sm shadow-stone-200/40 hover:border-slate-400"
            >
              <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
              <p class="mt-4 text-sm leading-7 text-slate-600">{item.description}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <footer class="border-t border-stone-200/70 bg-[#f4f1e8]">
    <div class="mx-auto flex max-w-7xl flex-col gap-5 px-5 py-8 text-sm text-slate-600 lg:flex-row lg:items-center lg:justify-between lg:px-8">
      <p class="max-w-3xl leading-7">{content.footer.note}</p>
      <a
        href={siteMeta.mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="w-fit rounded-full border border-slate-300 px-5 py-3 font-semibold text-slate-800 hover:border-slate-900 hover:text-slate-950"
      >
        {content.footer.mapsLabel}
      </a>
    </div>
  </footer>
</div>
