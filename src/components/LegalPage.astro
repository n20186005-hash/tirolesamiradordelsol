---
import type { Locale } from "../data/site";

type Section = {
  title: string;
  paragraphs?: string[];
  bullets?: string[];
};

interface Props {
  locale: Locale;
  homeLabel: string;
  backLabel: string;
  title: string;
  updatedLabel: string;
  updatedValue: string;
  intro: string;
  sections: Section[];
}

const { locale, homeLabel, backLabel, title, updatedLabel, updatedValue, intro, sections } = Astro.props;
const homeHref = locale === "zh" ? "/" : `/${locale}/`;
---

<main class="mx-auto max-w-5xl px-5 py-10 lg:px-8 lg:py-14">
  <div class="flex flex-wrap items-center gap-3 text-sm text-slate-600">
    <a href={homeHref} class="rounded-full border border-stone-300 bg-white/70 px-4 py-2 hover:border-slate-500 hover:text-slate-950">
      {backLabel}
    </a>
    <span>/</span>
    <a href={homeHref} class="hover:text-slate-950">{homeLabel}</a>
    <span>/</span>
    <span class="text-slate-950">{title}</span>
  </div>

  <section class="mt-8 rounded-[2rem] border border-stone-200/80 bg-white/85 p-8 shadow-sm shadow-stone-200/40 lg:p-10">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold tracking-[0.18em] text-slate-500 uppercase">{updatedLabel}</p>
      <p class="mt-3 text-base text-slate-700">{updatedValue}</p>
      <h1 class="mt-6 text-4xl font-semibold tracking-tight text-slate-950">{title}</h1>
      <p class="mt-6 text-base leading-8 text-slate-650">{intro}</p>
    </div>

    <div class="mt-10 grid gap-6">
      {
        sections.map((section) => (
          <article class="rounded-[1.5rem] border border-stone-200/80 bg-[#faf8f3] p-6">
            <h2 class="text-xl font-semibold text-slate-950">{section.title}</h2>
            {section.paragraphs?.map((paragraph) => (
              <p class="mt-4 text-sm leading-8 text-slate-700">{paragraph}</p>
            ))}
            {section.bullets && (
              <ul class="mt-4 space-y-3 text-sm leading-8 text-slate-700">
                {section.bullets.map((item) => <li class="flex gap-3"><span class="mt-3 h-1.5 w-1.5 rounded-full bg-slate-500"></span><span>{item}</span></li>)}
              </ul>
            )}
          </article>
        ))
      }
      <slot />
    </div>
  </section>
</main>
