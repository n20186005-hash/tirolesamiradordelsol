---
type CookieCategory = {
  key: "necessary" | "analytics" | "preferences" | "marketing";
  title: string;
  description: string;
  statusLabel: string;
  statusValue: string;
  locked?: boolean;
  detailTitle: string;
  detailBody: string;
};

interface Props {
  categories: CookieCategory[];
  consentTitle: string;
  consentBody: string;
  note: string;
  saveLabel: string;
  rejectLabel: string;
  savedMessage: string;
  rejectedMessage: string;
}

const { categories, consentTitle, consentBody, note, saveLabel, rejectLabel, savedMessage, rejectedMessage } = Astro.props;
---

<section class="rounded-[1.75rem] border border-stone-200/80 bg-white p-6 shadow-sm shadow-stone-200/30 lg:p-8">
  <div class="grid gap-4">
    {
      categories.map((category) => (
        <article class="rounded-[1.5rem] border border-stone-200/80 bg-[#faf8f3] p-5">
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
            <div class="max-w-3xl">
              <h2 class="text-lg font-semibold text-slate-950">{category.title}</h2>
              <p class="mt-3 text-sm leading-7 text-slate-700">{category.description}</p>
              <div class="mt-4 rounded-2xl border border-stone-200 bg-white/80 p-4">
                <div class="text-xs tracking-[0.16em] text-slate-500 uppercase">{category.statusLabel}</div>
                <div class="mt-2 text-sm font-medium text-slate-900">{category.statusValue}</div>
                <p class="mt-3 text-sm leading-7 text-slate-600">{category.detailBody}</p>
              </div>
            </div>
            <label class:list={["inline-flex items-center gap-3 rounded-full border px-4 py-2 text-sm font-medium", category.locked ? "border-slate-300 bg-slate-100 text-slate-500" : "border-slate-300 bg-white text-slate-800"]}>
              <input
                type="checkbox"
                class="h-4 w-4 accent-slate-900"
                data-cookie-toggle={category.key}
                checked={category.locked}
                disabled={category.locked}
              />
              <span>{category.locked ? category.statusValue : category.detailTitle}</span>
            </label>
          </div>
        </article>
      ))
    }
  </div>

  <div class="mt-8 rounded-[1.5rem] border border-stone-200/80 bg-[#f7f5ef] p-6">
    <h2 class="text-lg font-semibold text-slate-950">{consentTitle}</h2>
    <p class="mt-4 text-sm leading-7 text-slate-700">{consentBody}</p>
    <p class="mt-4 text-sm leading-7 text-slate-600">{note}</p>
    <div class="mt-6 flex flex-wrap gap-3">
      <button
        type="button"
        data-cookie-action="save"
        class="rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800"
      >
        {saveLabel}
      </button>
      <button
        type="button"
        data-cookie-action="reject"
        class="rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:border-slate-900 hover:text-slate-950"
      >
        {rejectLabel}
      </button>
    </div>
    <p class="mt-4 text-sm text-slate-600" data-cookie-message></p>
  </div>
</section>

<script is:inline define:vars={{ savedMessage, rejectedMessage }}>
  const storageKey = "site-cookie-preferences";
  const toggles = Array.from(document.querySelectorAll("[data-cookie-toggle]"));
  const messageEl = document.querySelector("[data-cookie-message]");

  const readPreferences = () => {
    try {
      const raw = window.localStorage.getItem(storageKey);
      if (!raw) return { analytics: false, preferences: true, marketing: false };
      return JSON.parse(raw);
    } catch {
      return { analytics: false, preferences: true, marketing: false };
    }
  };

  const applyPreferences = (preferences) => {
    toggles.forEach((toggle) => {
      const key = toggle.getAttribute("data-cookie-toggle");
      if (!key || toggle.disabled) return;
      toggle.checked = Boolean(preferences[key]);
    });
  };

  const savePreferences = (preferences, text) => {
    window.localStorage.setItem(storageKey, JSON.stringify(preferences));
    applyPreferences(preferences);
    if (messageEl) messageEl.textContent = text;
  };

  applyPreferences(readPreferences());

  document.querySelector('[data-cookie-action="save"]')?.addEventListener("click", () => {
    const preferences = { analytics: false, preferences: false, marketing: false };
    toggles.forEach((toggle) => {
      const key = toggle.getAttribute("data-cookie-toggle");
      if (!key || toggle.disabled) return;
      preferences[key] = toggle.checked;
    });
    savePreferences(preferences, savedMessage);
  });

  document.querySelector('[data-cookie-action="reject"]')?.addEventListener("click", () => {
    savePreferences({ analytics: false, preferences: false, marketing: false }, rejectedMessage);
  });
</script>
